{
  "_comment": "Phase 2 — REPLACE the REPLACE_ME hostname with the Cloud Run service URL after deploying advisor/.",
  "display_information": {
    "name": "Acreditta Advisor",
    "description": "M&A coach for Acreditta's exit process (Anabella's interlocutor)",
    "background_color": "#5a3a8c"
  },
  "features": {
    "bot_user": {
      "display_name": "Acreditta Advisor",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "chat:write.public",
        "im:history",
        "im:read",
        "im:write",
        "channels:history",
        "groups:history",
        "users:read",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://REPLACE_ME-advisor.run.app/slack/events",
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
