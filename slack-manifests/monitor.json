{
  "display_information": {
    "name": "Acreditta Monitor",
    "description": "Daily M&A signal scanner for Acreditta's exit process",
    "background_color": "#1f1f3a"
  },
  "features": {
    "bot_user": {
      "display_name": "Acreditta Monitor",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "channels:read"
