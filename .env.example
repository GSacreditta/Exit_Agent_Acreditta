# --- Required for all agents ---
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql+psycopg://app:LOCAL_PW@localhost:5432/exit_agent

# --- Monitor ---
SERPAPI_KEY=
PARALLEL_API_KEY=
SLACK_BOT_TOKEN=xoxb-...                 # token of acreditta-monitor app
SLACK_CHANNEL_ID=C0123456789             # shared exit channel ID

# --- Monitor knobs ---
CLAUDE_MODEL=claude-haiku-4-5            # Monitor stays on Haiku
USE_PARALLEL_EXTRACT=true
SLACK_MODE=digest                        # digest | per_item
SERPAPI_NUM=10
LOOKBACK_HOURS=24

# --- Cloud SQL (only needed when running on Cloud Run) ---
DB_INSTANCE_CONNECTION_NAME=             # e.g. exiti-agent-acreditta:us-central1:acreditta-exit-db
DB_NAME=exit_agent
DB_USER=app
DB_PASSWORD=
